{
  "OutputPath": "docs/wiki",
  "DefaultModel": "gpt-4o",
  "Provider": "azure-openai",
  "AgentMdPath": "AGENTS.md",
  "MaxFilesToAnalyze": 500,
  "EnableIncrementalUpdates": true,
  "LlmTimeoutSeconds": 300,
  "MaxLlmSummaryChars": 16000,
  "IgnorePatterns": [
    "**/bin/**",
    "**/obj/**",
    "**/node_modules/**",
    "**/.git/**",
    "**/packages/**",
    "**/*.min.js",
    "**/*.min.css",
    "**/docs/wiki/**",
    "**/.agentwiki/**"
  ],
  "AzureOpenAI": {
    "Endpoint": "",
    "DeploymentName": "",
    "ApiKey": "",
    "UseManagedIdentity": false
  },
  "OpenAI": {
    "Endpoint": "",
    "ApiKey": "",
    "Model": ""
  }
}
