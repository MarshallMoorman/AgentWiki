<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ── Page chrome ─────────────────────────────────────────── -->
  <Style Selector="TextBlock.page-title">
    <Setter Property="FontSize" Value="{DynamicResource AwFont.PageTitle}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource AwBrush.Text}" />
    <Setter Property="LetterSpacing" Value="-0.3" />
  </Style>

  <Style Selector="TextBlock.page-subtitle">
    <Setter Property="FontSize" Value="13.5" />
    <Setter Property="Foreground" Value="{DynamicResource AwBrush.TextMuted}" />
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="LineHeight" Value="20" />
    <Setter Property="Margin" Value="0,4,0,0" />
  </Style>

  <Style Selector="TextBlock.section-title">
    <Setter Property="FontSize" Value="{DynamicResource AwFont.Section}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource AwBrush.TextMuted}" />
    <Setter Property="LetterSpacing" Value="0.6" />
    <Setter Property="Margin" Value="0,4,0,8" />
  </Style>

  <Style Selector="TextBlock.muted">
    <Setter Property="Foreground" Value="{DynamicResource AwBrush.TextMuted}" />
  </Style>

  <Style Selector="TextBlock.dim">
    <Setter Property="Foreground" Value="{DynamicResource AwBrush.TextDim}" />
  </Style>

  <Style Selector="TextBlock.warning-text">
    <Setter Property="Foreground" Value="{DynamicResource AwBrush.Warning}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style Selector="TextBlock.success-text">
    <Setter Property="Foreground" Value="{DynamicResource AwBrush.Success}" />
  </Style>

  <Style Selector="TextBlock.field-label">
    <Setter Property="Foreground" Value="{DynamicResource AwBrush.TextMuted}" />
    <Setter Property="FontSize" Value="12.5" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <!-- ── Cards ───────────────────────────────────────────────── -->
  <Style Selector="Border.card">
    <Setter Property="Background" Value="{DynamicResource AwBrush.BgElevated}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AwBrush.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource AwRadius.Lg}" />
    <Setter Property="Padding" Value="{DynamicResource AwPad.Card}" />
    <Setter Property="BoxShadow" Value="0 8 28 0 #28000000" />
  </Style>

  <Style Selector="Border.card-flat">
    <Setter Property="Background" Value="{DynamicResource AwBrush.BgSubtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AwBrush.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource AwRadius.Md}" />
    <Setter Property="Padding" Value="14" />
  </Style>

  <Style Selector="Border.card-accent">
    <Setter Property="Background" Value="{DynamicResource AwBrush.AccentSoft}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AwBrush.Accent}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource AwRadius.Lg}" />
    <Setter Property="Padding" Value="{DynamicResource AwPad.Card}" />
  </Style>

  <Style Selector="Border.hero">
    <Setter Property="Background" Value="{DynamicResource AwBrush.AccentSoft}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AwBrush.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource AwRadius.Xl}" />
    <Setter Property="Padding" Value="20" />
  </Style>

  <!-- ── Status chips ────────────────────────────────────────── -->
  <Style Selector="Border.chip">
    <Setter Property="Background" Value="{DynamicResource AwBrush.ChipBg}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AwBrush.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource AwRadius.Pill}" />
    <Setter Property="Padding" Value="10,4" />
  </Style>

  <Style Selector="Border.chip-success">
    <Setter Property="Background" Value="{DynamicResource AwBrush.SuccessSoft}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AwBrush.Success}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource AwRadius.Pill}" />
    <Setter Property="Padding" Value="10,4" />
  </Style>

  <Style Selector="Border.chip-warning">
    <Setter Property="Background" Value="{DynamicResource AwBrush.WarningSoft}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AwBrush.Warning}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource AwRadius.Pill}" />
    <Setter Property="Padding" Value="10,4" />
  </Style>

  <Style Selector="Border.chip TextBlock">
    <Setter Property="FontSize" Value="11.5" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource AwBrush.TextMuted}" />
  </Style>

  <Style Selector="Border.chip-success TextBlock">
    <Setter Property="FontSize" Value="11.5" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource AwBrush.Success}" />
  </Style>

  <Style Selector="Border.chip-warning TextBlock">
    <Setter Property="FontSize" Value="11.5" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource AwBrush.Warning}" />
  </Style>

  <!-- ── Buttons ─────────────────────────────────────────────── -->
  <Style Selector="Button.primary">
    <Setter Property="Background" Value="{DynamicResource AwBrush.AccentGradient}" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="{DynamicResource AwRadius.Md}" />
    <Setter Property="Padding" Value="16,9" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AwBrush.AccentHover}" />
  </Style>
  <Style Selector="Button.primary:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AwBrush.AccentDeep}" />
  </Style>
  <Style Selector="Button.primary:disabled">
    <Setter Property="Opacity" Value="0.45" />
  </Style>

  <Style Selector="Button.secondary">
    <Setter Property="Background" Value="{DynamicResource AwBrush.BgElevated}" />
    <Setter Property="Foreground" Value="{DynamicResource AwBrush.Text}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AwBrush.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource AwRadius.Md}" />
    <Setter Property="Padding" Value="14,8" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.secondary:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AwBrush.BgHover}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AwBrush.BorderStrong}" />
  </Style>

  <Style Selector="Button.ghost">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource AwBrush.TextMuted}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="{DynamicResource AwRadius.Md}" />
    <Setter Property="Padding" Value="10,6" />
    <Setter Property="FontSize" Value="12.5" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AwBrush.BgHover}" />
    <Setter Property="Foreground" Value="{DynamicResource AwBrush.Text}" />
  </Style>

  <Style Selector="Button.danger-ghost">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource AwBrush.Danger}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AwBrush.Danger}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource AwRadius.Md}" />
    <Setter Property="Padding" Value="14,8" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>

  <!-- ── Nav rail ────────────────────────────────────────────── -->
  <Style Selector="ListBox.nav-rail">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="8,4" />
  </Style>

  <Style Selector="ListBox.nav-rail ListBoxItem">
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="0,2" />
    <Setter Property="CornerRadius" Value="{DynamicResource AwRadius.Md}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="MinHeight" Value="0" />
  </Style>

  <Style Selector="ListBox.nav-rail ListBoxItem:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AwBrush.BgHover}" />
  </Style>

  <Style Selector="ListBox.nav-rail ListBoxItem:selected /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AwBrush.NavSelected}" />
  </Style>

  <Style Selector="ListBox.nav-rail ListBoxItem:selected:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AwBrush.NavSelected}" />
  </Style>

  <!-- ── Inputs ──────────────────────────────────────────────── -->
  <Style Selector="TextBox.aw-input">
    <Setter Property="Background" Value="{DynamicResource AwBrush.BgSubtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AwBrush.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource AwRadius.Md}" />
    <Setter Property="Padding" Value="10,8" />
    <Setter Property="Foreground" Value="{DynamicResource AwBrush.Text}" />
    <Setter Property="CaretBrush" Value="{DynamicResource AwBrush.Accent}" />
    <Setter Property="SelectionBrush" Value="{DynamicResource AwBrush.AccentSoft}" />
  </Style>
  <Style Selector="TextBox.aw-input:focus">
    <Setter Property="BorderBrush" Value="{DynamicResource AwBrush.Accent}" />
  </Style>

  <Style Selector="TextBox.aw-code">
    <Setter Property="Background" Value="{DynamicResource AwBrush.CodeBg}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AwBrush.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource AwRadius.Md}" />
    <Setter Property="Padding" Value="12" />
    <Setter Property="FontFamily" Value="{DynamicResource AwFont.Mono}" />
    <Setter Property="FontSize" Value="12.5" />
    <Setter Property="Foreground" Value="{DynamicResource AwBrush.Text}" />
  </Style>

  <Style Selector="ComboBox.aw-input">
    <Setter Property="Background" Value="{DynamicResource AwBrush.BgSubtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AwBrush.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource AwRadius.Md}" />
    <Setter Property="Padding" Value="8,6" />
    <Setter Property="MinHeight" Value="36" />
  </Style>

  <Style Selector="NumericUpDown.aw-input">
    <Setter Property="Background" Value="{DynamicResource AwBrush.BgSubtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AwBrush.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource AwRadius.Md}" />
    <Setter Property="MinHeight" Value="36" />
  </Style>

  <!-- ── Data surfaces ───────────────────────────────────────── -->
  <Style Selector="DataGrid.aw-grid">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource AwBrush.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource AwRadius.Md}" />
    <Setter Property="GridLinesVisibility" Value="Horizontal" />
    <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource AwBrush.Border}" />
    <Setter Property="RowBackground" Value="Transparent" />
    <Setter Property="HeadersVisibility" Value="Column" />
    <Setter Property="IsReadOnly" Value="True" />
  </Style>

  <Style Selector="ListBox.aw-list">
    <Setter Property="Background" Value="{DynamicResource AwBrush.BgSubtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AwBrush.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource AwRadius.Md}" />
    <Setter Property="Padding" Value="4" />
  </Style>

  <Style Selector="TreeView.aw-tree">
    <Setter Property="Background" Value="{DynamicResource AwBrush.BgSubtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AwBrush.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource AwRadius.Md}" />
    <Setter Property="Padding" Value="6" />
  </Style>

  <!-- ── Window root ─────────────────────────────────────────── -->
  <Style Selector="Window.aw-window">
    <Setter Property="Background" Value="{DynamicResource AwBrush.Bg}" />
    <Setter Property="Foreground" Value="{DynamicResource AwBrush.Text}" />
    <!-- Do not force a custom FontFamily here — platform default supports all weights. -->
    <Setter Property="FontSize" Value="13.5" />
  </Style>

  <Style Selector="ScrollViewer.page-scroll">
    <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
    <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
  </Style>
</Styles>
