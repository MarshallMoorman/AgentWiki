<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!--
    AgentWiki visual system — dark-first, indigo accent, soft glass surfaces.
    Tuned for long reading sessions (wiki/logs) and clear primary actions.
  -->

  <ResourceDictionary.ThemeDictionaries>
    <!-- ── Dark (default product look) ─────────────────────────── -->
    <ResourceDictionary x:Key="Dark">
      <Color x:Key="Aw.BgDeep">#0B0D12</Color>
      <Color x:Key="Aw.Bg">#10131A</Color>
      <Color x:Key="Aw.BgElevated">#161B26</Color>
      <Color x:Key="Aw.BgHover">#1C2333</Color>
      <Color x:Key="Aw.BgSubtle">#121722</Color>
      <Color x:Key="Aw.Border">#2A3347</Color>
      <Color x:Key="Aw.BorderStrong">#3A4660</Color>
      <Color x:Key="Aw.Text">#E8EDF7</Color>
      <Color x:Key="Aw.TextMuted">#93A0B8</Color>
      <Color x:Key="Aw.TextDim">#6B7894</Color>
      <Color x:Key="Aw.Accent">#8B7CFF</Color>
      <Color x:Key="Aw.AccentHover">#A396FF</Color>
      <Color x:Key="Aw.AccentDeep">#5B4FD6</Color>
      <Color x:Key="Aw.AccentSoft">#2A2550</Color>
      <Color x:Key="Aw.AccentGlow">#3D3480</Color>
      <Color x:Key="Aw.Success">#3DDC97</Color>
      <Color x:Key="Aw.SuccessSoft">#143528</Color>
      <Color x:Key="Aw.Warning">#F5C15C</Color>
      <Color x:Key="Aw.WarningSoft">#3A2E14</Color>
      <Color x:Key="Aw.Danger">#FF6B7A</Color>
      <Color x:Key="Aw.DangerSoft">#3A151C</Color>
      <Color x:Key="Aw.Info">#5CB8FF</Color>
      <Color x:Key="Aw.Teal">#2DD4BF</Color>
      <Color x:Key="Aw.CodeBg">#0A0C11</Color>
      <Color x:Key="Aw.Sidebar">#0D1018</Color>
      <Color x:Key="Aw.HeaderStart">#14182A</Color>
      <Color x:Key="Aw.HeaderEnd">#10131A</Color>
      <Color x:Key="Aw.ChipBg">#1A2030</Color>
      <Color x:Key="Aw.NavSelectedStart">#2E2860</Color>
      <Color x:Key="Aw.NavSelectedEnd">#1E1A40</Color>
      <Color x:Key="Aw.Shadow">#000000</Color>
    </ResourceDictionary>

    <!-- ── Light ──────────────────────────────────────────────── -->
    <ResourceDictionary x:Key="Light">
      <Color x:Key="Aw.BgDeep">#EEF1F8</Color>
      <Color x:Key="Aw.Bg">#F5F7FC</Color>
      <Color x:Key="Aw.BgElevated">#FFFFFF</Color>
      <Color x:Key="Aw.BgHover">#E8ECF6</Color>
      <Color x:Key="Aw.BgSubtle">#EBEEF6</Color>
      <Color x:Key="Aw.Border">#D5DCEC</Color>
      <Color x:Key="Aw.BorderStrong">#B8C2D9</Color>
      <Color x:Key="Aw.Text">#151A28</Color>
      <Color x:Key="Aw.TextMuted">#5A667F</Color>
      <Color x:Key="Aw.TextDim">#8793AB</Color>
      <Color x:Key="Aw.Accent">#6C5CE7</Color>
      <Color x:Key="Aw.AccentHover">#5A4BD1</Color>
      <Color x:Key="Aw.AccentDeep">#4A3BB8</Color>
      <Color x:Key="Aw.AccentSoft">#EDE9FF</Color>
      <Color x:Key="Aw.AccentGlow">#D8D1FF</Color>
      <Color x:Key="Aw.Success">#0FA968</Color>
      <Color x:Key="Aw.SuccessSoft">#D8F5E8</Color>
      <Color x:Key="Aw.Warning">#C98900</Color>
      <Color x:Key="Aw.WarningSoft">#FFF3D6</Color>
      <Color x:Key="Aw.Danger">#E03E52</Color>
      <Color x:Key="Aw.DangerSoft">#FDE4E8</Color>
      <Color x:Key="Aw.Info">#1A7FD4</Color>
      <Color x:Key="Aw.Teal">#0D9488</Color>
      <Color x:Key="Aw.CodeBg">#F0F3FA</Color>
      <Color x:Key="Aw.Sidebar">#E9EDF7</Color>
      <Color x:Key="Aw.HeaderStart">#FFFFFF</Color>
      <Color x:Key="Aw.HeaderEnd">#F5F7FC</Color>
      <Color x:Key="Aw.ChipBg">#E8ECF6</Color>
      <Color x:Key="Aw.NavSelectedStart">#E4DEFF</Color>
      <Color x:Key="Aw.NavSelectedEnd">#EDE9FF</Color>
      <Color x:Key="Aw.Shadow">#1A1F3A</Color>
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>

  <!-- Shared brushes (theme-aware via DynamicResource on Color keys) -->
  <SolidColorBrush x:Key="AwBrush.BgDeep" Color="{DynamicResource Aw.BgDeep}" />
  <SolidColorBrush x:Key="AwBrush.Bg" Color="{DynamicResource Aw.Bg}" />
  <SolidColorBrush x:Key="AwBrush.BgElevated" Color="{DynamicResource Aw.BgElevated}" />
  <SolidColorBrush x:Key="AwBrush.BgHover" Color="{DynamicResource Aw.BgHover}" />
  <SolidColorBrush x:Key="AwBrush.BgSubtle" Color="{DynamicResource Aw.BgSubtle}" />
  <SolidColorBrush x:Key="AwBrush.Border" Color="{DynamicResource Aw.Border}" />
  <SolidColorBrush x:Key="AwBrush.BorderStrong" Color="{DynamicResource Aw.BorderStrong}" />
  <SolidColorBrush x:Key="AwBrush.Text" Color="{DynamicResource Aw.Text}" />
  <SolidColorBrush x:Key="AwBrush.TextMuted" Color="{DynamicResource Aw.TextMuted}" />
  <SolidColorBrush x:Key="AwBrush.TextDim" Color="{DynamicResource Aw.TextDim}" />
  <SolidColorBrush x:Key="AwBrush.Accent" Color="{DynamicResource Aw.Accent}" />
  <SolidColorBrush x:Key="AwBrush.AccentHover" Color="{DynamicResource Aw.AccentHover}" />
  <SolidColorBrush x:Key="AwBrush.AccentDeep" Color="{DynamicResource Aw.AccentDeep}" />
  <SolidColorBrush x:Key="AwBrush.AccentSoft" Color="{DynamicResource Aw.AccentSoft}" />
  <SolidColorBrush x:Key="AwBrush.Success" Color="{DynamicResource Aw.Success}" />
  <SolidColorBrush x:Key="AwBrush.SuccessSoft" Color="{DynamicResource Aw.SuccessSoft}" />
  <SolidColorBrush x:Key="AwBrush.Warning" Color="{DynamicResource Aw.Warning}" />
  <SolidColorBrush x:Key="AwBrush.WarningSoft" Color="{DynamicResource Aw.WarningSoft}" />
  <SolidColorBrush x:Key="AwBrush.Danger" Color="{DynamicResource Aw.Danger}" />
  <SolidColorBrush x:Key="AwBrush.Info" Color="{DynamicResource Aw.Info}" />
  <SolidColorBrush x:Key="AwBrush.Teal" Color="{DynamicResource Aw.Teal}" />
  <SolidColorBrush x:Key="AwBrush.CodeBg" Color="{DynamicResource Aw.CodeBg}" />
  <SolidColorBrush x:Key="AwBrush.Sidebar" Color="{DynamicResource Aw.Sidebar}" />
  <SolidColorBrush x:Key="AwBrush.ChipBg" Color="{DynamicResource Aw.ChipBg}" />

  <LinearGradientBrush x:Key="AwBrush.Header" StartPoint="0%,0%" EndPoint="100%,100%">
    <GradientStop Offset="0" Color="{DynamicResource Aw.HeaderStart}" />
    <GradientStop Offset="1" Color="{DynamicResource Aw.HeaderEnd}" />
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="AwBrush.AccentGradient" StartPoint="0%,0%" EndPoint="100%,100%">
    <GradientStop Offset="0" Color="{DynamicResource Aw.Accent}" />
    <GradientStop Offset="1" Color="{DynamicResource Aw.AccentDeep}" />
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="AwBrush.LogoGradient" StartPoint="0%,0%" EndPoint="100%,100%">
    <GradientStop Offset="0" Color="#A78BFA" />
    <GradientStop Offset="0.5" Color="#8B7CFF" />
    <GradientStop Offset="1" Color="#2DD4BF" />
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="AwBrush.NavSelected" StartPoint="0%,0%" EndPoint="100%,0%">
    <GradientStop Offset="0" Color="{DynamicResource Aw.NavSelectedStart}" />
    <GradientStop Offset="1" Color="{DynamicResource Aw.NavSelectedEnd}" />
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="AwBrush.SidebarGlow" StartPoint="0%,0%" EndPoint="0%,100%">
    <GradientStop Offset="0" Color="#1A1640" />
    <GradientStop Offset="0.35" Color="{DynamicResource Aw.Sidebar}" />
    <GradientStop Offset="1" Color="{DynamicResource Aw.Sidebar}" />
  </LinearGradientBrush>

  <!--
    Fonts: prefer single, real typefaces — Avalonia composite stacks
    (e.g. "Inter, SF Pro Text, …") throw Could not create glyphTypeface when a
    requested weight (SemiBold/DemiBold) is missing from the first face.
    Body uses the platform default; mono is set in App.axaml.cs per OS.
  -->
  <FontFamily x:Key="AwFont.Body">$Default</FontFamily>
  <!-- Placeholder; replaced at startup with a platform mono face (see AppFonts). -->
  <FontFamily x:Key="AwFont.Mono">$Default</FontFamily>

  <CornerRadius x:Key="AwRadius.Sm">6</CornerRadius>
  <CornerRadius x:Key="AwRadius.Md">10</CornerRadius>
  <CornerRadius x:Key="AwRadius.Lg">14</CornerRadius>
  <CornerRadius x:Key="AwRadius.Xl">18</CornerRadius>
  <CornerRadius x:Key="AwRadius.Pill">999</CornerRadius>

  <Thickness x:Key="AwPad.Card">18</Thickness>
  <Thickness x:Key="AwPad.Page">20,16,20,20</Thickness>
  <x:Double x:Key="AwFont.PageTitle">26</x:Double>
  <x:Double x:Key="AwFont.Section">14</x:Double>
</ResourceDictionary>
