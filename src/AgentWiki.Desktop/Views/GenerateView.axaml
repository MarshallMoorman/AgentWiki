<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AgentWiki.Desktop.ViewModels"
             x:Class="AgentWiki.Desktop.Views.GenerateView"
             x:DataType="vm:GenerateViewModel">
  <ScrollViewer Classes="page-scroll">
    <StackPanel Spacing="16">
      <StackPanel Spacing="4">
        <TextBlock Text="Generate" Classes="page-title" />
        <TextBlock Text="Full multi-step wiki generation — same engine as agent-wiki generate. Works offline without LLM credentials."
                   Classes="page-subtitle" />
      </StackPanel>

      <Grid ColumnDefinitions="*,*" >
        <!-- Options -->
        <Border Classes="card" Margin="0,0,8,0">
          <StackPanel Spacing="12">
            <TextBlock Text="RUN OPTIONS" Classes="section-title" />

            <Grid ColumnDefinitions="110,*" RowDefinitions="Auto,Auto,Auto,Auto" >
              <TextBlock Grid.Row="0" Text="Output" Classes="field-label" />
              <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding OutputPath}" Classes="aw-input" Margin="0,0,0,8" />

              <TextBlock Grid.Row="1" Text="Provider" Classes="field-label" />
              <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Provider}" Classes="aw-input" Margin="0,0,0,8" />

              <TextBlock Grid.Row="2" Text="Model" Classes="field-label" />
              <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Model}" Classes="aw-input" Margin="0,0,0,8" />

              <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Spacing="18" Margin="0,4,0,0">
                <CheckBox Content="Force overwrite" IsChecked="{Binding Force}" />
                <CheckBox Content="Dry-run" IsChecked="{Binding DryRun}" />
              </StackPanel>
            </Grid>

            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,8,0,0">
              <Button Content="Run generate" Classes="primary" Command="{Binding RunCommand}" />
              <Button Content="Cancel" Classes="danger-ghost" Command="{Binding CancelCommand}" />
              <Border Classes="chip" VerticalAlignment="Center" IsVisible="{Binding IsRunning}">
                <TextBlock Text="{Binding StatusText}" />
              </Border>
              <TextBlock Text="{Binding StatusText}"
                         Classes="muted"
                         VerticalAlignment="Center"
                         IsVisible="{Binding !IsRunning}" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Progress -->
        <Border Grid.Column="1" Classes="card" Margin="8,0,0,0">
          <StackPanel Spacing="10">
            <TextBlock Text="PROGRESS" Classes="section-title" />
            <ListBox ItemsSource="{Binding ProgressLines}" Classes="aw-list" MaxHeight="220" MinHeight="120" />
            <TextBlock Text="{Binding ResultMessage}"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource AwBrush.Accent}" />
          </StackPanel>
        </Border>
      </Grid>

      <Border Classes="card">
        <StackPanel Spacing="12">
          <TextBlock Text="RESULTS" Classes="section-title" />
          <DataGrid ItemsSource="{Binding ResultRows}" Classes="aw-grid" AutoGenerateColumns="False" MaxHeight="240">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Property" Binding="{Binding Key}" Width="2*" />
              <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="5*" />
            </DataGrid.Columns>
          </DataGrid>

          <Grid ColumnDefinitions="*,*" IsVisible="{Binding FilesWritten.Count}">
            <StackPanel Margin="0,0,8,0" Spacing="8">
              <TextBlock Text="FILES WRITTEN" Classes="section-title" />
              <ListBox ItemsSource="{Binding FilesWritten}" Classes="aw-list" MaxHeight="160" />
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0,0,0" Spacing="8" IsVisible="{Binding Warnings.Count}">
              <TextBlock Text="WARNINGS" Classes="section-title" />
              <ItemsControl ItemsSource="{Binding Warnings}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="chip-warning" Margin="0,0,0,6" Padding="10,6">
                      <TextBlock Text="{Binding}" Classes="warning-text" />
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
