<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AgentWiki.Desktop.ViewModels"
        xmlns:models="using:AgentWiki.Desktop.Models"
        xmlns:views="using:AgentWiki.Desktop.Views"
        x:Class="AgentWiki.Desktop.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Classes="aw-window"
        Title="{Binding AppTitle}"
        Width="1280"
        Height="820"
        MinWidth="980"
        MinHeight="620"
        ExtendClientAreaToDecorationsHint="False">

  <Window.DataTemplates>
    <DataTemplate DataType="vm:DashboardViewModel">
      <views:DashboardView />
    </DataTemplate>
    <DataTemplate DataType="vm:GenerateViewModel">
      <views:GenerateView />
    </DataTemplate>
    <DataTemplate DataType="vm:UpdateViewModel">
      <views:UpdateView />
    </DataTemplate>
    <DataTemplate DataType="vm:SetupViewModel">
      <views:SetupView />
    </DataTemplate>
    <DataTemplate DataType="vm:SettingsViewModel">
      <views:SettingsView />
    </DataTemplate>
    <DataTemplate DataType="vm:ProviderViewModel">
      <views:ProviderView />
    </DataTemplate>
    <DataTemplate DataType="vm:WikiBrowserViewModel">
      <views:WikiBrowserView />
    </DataTemplate>
    <DataTemplate DataType="vm:LogsViewModel">
      <views:LogsView />
    </DataTemplate>
  </Window.DataTemplates>

  <DockPanel>
    <!-- ── Status bar ─────────────────────────────────────────── -->
    <Border DockPanel.Dock="Bottom"
            Background="{DynamicResource AwBrush.BgElevated}"
            BorderBrush="{DynamicResource AwBrush.Border}"
            BorderThickness="0,1,0,0"
            Padding="16,8">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <Ellipse Width="7" Height="7" VerticalAlignment="Center">
            <Ellipse.Fill>
              <SolidColorBrush Color="{DynamicResource Aw.Accent}" />
            </Ellipse.Fill>
          </Ellipse>
          <TextBlock Text="{Binding StatusMessage}"
                     TextTrimming="CharacterEllipsis"
                     VerticalAlignment="Center"
                     Classes="muted"
                     FontSize="12.5" />
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Border Classes="chip">
            <TextBlock Text="{Binding StatusProvider, StringFormat='{}{0}'}" />
          </Border>
          <Border Classes="chip">
            <TextBlock Text="{Binding StatusModel}" />
          </Border>
          <Border Classes="chip">
            <TextBlock Text="{Binding StatusTimeout}" />
          </Border>
          <Border Classes="chip-success" IsVisible="{Binding IsLlmReady}">
            <TextBlock Text="{Binding StatusReady}" />
          </Border>
          <Border Classes="chip-warning" IsVisible="{Binding !IsLlmReady}">
            <TextBlock Text="{Binding StatusReady}" MaxWidth="280" TextTrimming="CharacterEllipsis" />
          </Border>
          <Button Content="Logs folder"
                  Command="{Binding OpenLogFolderCommand}"
                  Classes="ghost"
                  FontSize="12" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- ── Header ─────────────────────────────────────────────── -->
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource AwBrush.Header}"
            BorderBrush="{DynamicResource AwBrush.Border}"
            BorderThickness="0,0,0,1"
            Padding="16,12">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <!-- Brand -->
        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
          <Border Width="36" Height="36" CornerRadius="10"
                  Background="{DynamicResource AwBrush.LogoGradient}"
                  BoxShadow="0 4 16 0 #404C9AFF">
            <TextBlock Text="A"
                       FontWeight="Bold"
                       FontSize="18"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Border>
          <StackPanel Spacing="0" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="AgentWiki"
                         FontSize="17"
                         FontWeight="SemiBold"
                         LetterSpacing="-0.2" />
              <Border Classes="chip" Padding="7,2" VerticalAlignment="Center">
                <TextBlock Text="{Binding Version, StringFormat='v{0}'}" FontSize="10.5" />
              </Border>
            </StackPanel>
            <TextBlock Text="Desktop companion"
                       Classes="dim"
                       FontSize="11.5" />
          </StackPanel>
        </StackPanel>

        <!-- Repo picker -->
        <Border Grid.Column="1"
                Margin="24,0"
                Background="{DynamicResource AwBrush.BgSubtle}"
                BorderBrush="{DynamicResource AwBrush.Border}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="10,8"
                VerticalAlignment="Center">
          <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" RowDefinitions="Auto">
            <TextBlock Text="REPO"
                       Classes="dim"
                       FontSize="10"
                       FontWeight="Bold"
                       LetterSpacing="1"
                       VerticalAlignment="Center"
                       Margin="4,0,10,0" />
            <TextBox Grid.Column="1"
                     Text="{Binding RepoPath}"
                     Classes="aw-input"
                     PlaceholderText="~/path/to/repository"
                     MinWidth="240"
                     Margin="0,0,8,0" />
            <Button Grid.Column="2"
                    Content="Browse"
                    Classes="secondary"
                    Click="OnBrowseRepoClick"
                    Margin="0,0,6,0" />
            <Button Grid.Column="3"
                    Content="Load"
                    Classes="primary"
                    Click="OnLoadRepoClick"
                    Margin="0,0,6,0" />
            <ComboBox Grid.Column="4"
                      ItemsSource="{Binding RecentRepos}"
                      Classes="aw-input"
                      PlaceholderText="Recent"
                      MinWidth="140"
                      SelectionChanged="OnRecentSelectionChanged" />
          </Grid>
        </Border>

        <!-- Actions -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <StackPanel Spacing="0" HorizontalAlignment="Right" Margin="0,0,8,0">
            <TextBlock Text="Active"
                       Classes="dim"
                       FontSize="10"
                       HorizontalAlignment="Right" />
            <TextBlock Text="{Binding RepoDisplay}"
                       FontWeight="Medium"
                       FontSize="12.5"
                       MaxWidth="180"
                       TextTrimming="CharacterEllipsis"
                       HorizontalAlignment="Right" />
          </StackPanel>
          <Button Content="Open wiki"
                  Classes="secondary"
                  Command="{Binding OpenWikiFolderCommand}" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- ── Body ───────────────────────────────────────────────── -->
    <Grid ColumnDefinitions="228,*">
      <!-- Sidebar -->
      <Border Grid.Column="0"
              Background="{DynamicResource AwBrush.SidebarGlow}"
              BorderBrush="{DynamicResource AwBrush.Border}"
              BorderThickness="0,0,1,0"
              Padding="10,14,10,12">
        <DockPanel>
          <StackPanel DockPanel.Dock="Bottom" Spacing="8" Margin="6,12,6,4">
            <Border Height="1" Background="{DynamicResource AwBrush.Border}" Opacity="0.7" />
            <TextBlock Text="CLI stays primary for CI"
                       Classes="dim"
                       FontSize="11"
                       TextWrapping="Wrap"
                       LineHeight="15" />
            <TextBlock Text="Same engine · offline first"
                       Classes="dim"
                       FontSize="11" />
          </StackPanel>

          <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Text="NAVIGATE"
                       Classes="dim"
                       FontSize="10"
                       FontWeight="Bold"
                       LetterSpacing="1.2"
                       Margin="10,0,0,8" />

            <ListBox Classes="nav-rail"
                     ItemsSource="{Binding NavItems}"
                     SelectedItem="{Binding SelectedNav}">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="models:NavItem">
                  <Grid ColumnDefinitions="Auto,*,Auto" Margin="10,9">
                    <Border Width="28" Height="28"
                            CornerRadius="8"
                            Background="{DynamicResource AwBrush.AccentSoft}"
                            VerticalAlignment="Center">
                      <TextBlock Text="{Binding Glyph}"
                                 FontSize="13"
                                 Foreground="{DynamicResource AwBrush.Accent}"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" Spacing="1">
                      <TextBlock Text="{Binding Title}"
                                 FontWeight="SemiBold"
                                 FontSize="13" />
                      <TextBlock Text="{Binding Hint}"
                                 Classes="dim"
                                 FontSize="11" />
                    </StackPanel>
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </DockPanel>
        </DockPanel>
      </Border>

      <!-- Content -->
      <Border Grid.Column="1" Background="{DynamicResource AwBrush.Bg}">
        <ContentControl Content="{Binding CurrentContent}"
                        Margin="{DynamicResource AwPad.Page}" />
      </Border>
    </Grid>
  </DockPanel>
</Window>
